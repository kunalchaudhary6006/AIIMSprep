{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Represents the user's profile and data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" },
        "purchasedBatches": {
           "type": "array",
           "items": { "type": "string" }
        }
      },
      "required": ["uid", "email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "Stores user profiles with their enrolled batches."
    }
  }
}
