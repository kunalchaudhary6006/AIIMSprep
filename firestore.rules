rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) && data.keys().size() <= 5 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() <= 128 && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt is timestamp &&
             (!('purchasedBatches' in data) || (data.purchasedBatches is list && data.purchasedBatches.size() <= 50)) &&
             (!('trialEndsAt' in data) || data.trialEndsAt is number);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && 
                    isValidUser(incoming()) && 
                    incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && 
                    isValidUser(incoming()) && 
                    incoming().uid == existing().uid && 
                    incoming().createdAt == existing().createdAt && 
                    incoming().diff(existing()).affectedKeys().hasAny(['purchasedBatches', 'trialEndsAt']) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['purchasedBatches', 'trialEndsAt']);
      allow delete: if false;
    }
  }
}
